    ],
    "酥木餅 Quesadilla": [
        {name: "牛肉醬起司酥木餅 Taco Beef", price: 260},
        {name: "特製豬肉蛋酥木餅 Pork Mince W/Scrambled Eggs", price: 210},
        {name: "芥末手撕豬酥木餅 Wasabi Pulled Pork", price: 210},
        {name: "印度咖哩雞酥木餅 Curry Chicken", price: 210},
        {name: "墨西哥雞肉酥木餅 Taco Chicken", price: 210},
        {name: "菠菜蘑菇地瓜泥酥木餅 Mushroom-Spinach", price: 190}
    ],
    "捲餅 Wrap": [
        {name: "牛肉醬起司捲餅 Taco Beef", price: 260},
        {name: "醬燒豬五花捲餅 Soy-Stewed Pork Belly", price: 260},
        {name: "酥炸香料雞捲餅 Fried Chicken", price: 230},
        {name: "芥末手撕豬捲餅 Wasabi Pulled Pork", price: 210},
        {name: "印度咖哩雞捲餅 Curry Chicken", price: 210},
        {name: "墨西哥雞肉捲餅 Taco Chicken", price: 210},
        {name: "菠菜蘑菇地瓜泥捲餅 Mushroom-Spinach", price: 190}
    ],
    "飯捲 Burrito": [
        {name: "牛肉醬起司飯捲 Taco Beef", price: 270},
        {name: "墨西哥雞肉飯捲 Taco Chicken", price: 250}
    ],
    "小食 Snacks": [
        {name: "一片薯餅 Hash brown", price: 40},
        {name: "四塊雞塊 Nuggets", price: 50},
        {name: "黃金脆薯 Fries", price: 60},
        {name: "油醋沙拉 Vinaigrette Salad", price: 70},
        {name: "墨西哥沙拉 Mexican Salad", price: 90},
        {name: "原味美式雞翅 Classic Chicken Wings", price: 120},
        {name: "酸辣美式雞翅 Buffalo Chicken Wings", price: 150},
        {name: "墨西哥起司脆片 Classic Nachos", price: 180},
        {name: "牛肉醬起司脆片 Beef Nachos", price: 250}
    ],
    "飲品 Beverage": [
        {name: "紅茶 Black Tea", price: 40},
        {name: "南非國寶茶 Rooibos", price: 40},
        {name: "紅茶拿鐵 Milk Tea", price: 60},
        {name: "國寶拿鐵 Rooibos Latte", price: 60},
        {name: "美式咖啡 Americano", price: 60},
        {name: "拿鐵 Latte", price: 80},
        {name: "蘋果汁 Apple Juice", price: 70},
        {name: "Bundaberg 天然蘋果氣泡飲", price: 120}
    ],
    "早餐特價 Breakfast": [
        {name: "牛肉醬 Omelette", price: 110},
        {name: "蝦仁櫛瓜 Omelette", price: 110},
        {name: "虱目魚 Omelette", price: 100},
        {name: "菠菜 Omelette", price: 80},
        // Quesadilla
        {name: "牛肉醬 Quesadilla", price: 100},
        {name: "豬肉 Quesadilla", price: 80},
        {name: "芥末豬 Quesadilla", price: 80},
