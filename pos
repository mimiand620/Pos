        {name: "菠菜 Wrap", price: 130}
    ]
};

// ==================== 程式功能 ====================
let order = [];

function renderMenu() {
    const menuDiv = document.getElementById('menu');
    menuDiv.innerHTML = '';
    
    for (let category in menu) {
        const catDiv = document.createElement('div');
        catDiv.className = 'category';
        catDiv.innerHTML = `<div class="cat-title">${category}</div>`;
        
        menu[category].forEach(item => {
            const itemDiv = document.createElement('div');
            itemDiv.className = 'item';
            itemDiv.innerHTML = `${item.name} <span class="price">$${item.price}</span>`;
            itemDiv.onclick = () => addToOrder(item);
            catDiv.appendChild(itemDiv);
        });
        menuDiv.appendChild(catDiv);
    }
}

function addToOrder(item) {
    order.push(item);
    renderOrder();
}

function renderOrder() {
    const list = document.getElementById('order-list');
    list.innerHTML = '';
    
    order.forEach((item, index) => {
        const div = document.createElement('div');
        div.className = 'order-item';
        div.innerHTML = `
            ${item.name}
            <span>$${item.price} 
                <button class="remove" onclick="removeItem(${index})">刪除</button>
            </span>
        `;
        list.appendChild(div);
    });
    
    const total = order.reduce((sum, item) => sum + item.price, 0);
    document.getElementById('total').textContent = total;
}

function removeItem(index) {
    order.splice(index, 1);
    renderOrder();
}

function clearOrder() {
    if (confirm('確定要清空訂單嗎？')) {
        order = [];
        renderOrder();
    }
}

function checkout() {
    if (order.length === 0) {
        alert('訂單是空的！');
        return;
    }
    
    const total = order.reduce((sum, item) => sum + item.price, 0);
    let receipt = `自然捲 POS 收據\n`;
    receipt += `時間：${new Date().toLocaleString('zh-TW')}\n`;
    receipt += `================================\n`;
    
    order.forEach(item => {
        receipt += `${item.name} ...... $${item.price}\n`;
    });
    
    receipt += `================================\n`;
    receipt += `總計：NT$ ${total}\n`;
    receipt += `謝謝惠顧！🌯`;
    
    alert(receipt);
    
    // 清空訂單
    order = [];
    renderOrder();
}

// 啟動
renderMenu();
</script>

</body>
</html>
